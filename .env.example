# 이 파일은 커밋 OK. 실제 키는 `.env.local`에 넣고 `.env.local`은 절대 커밋 금지.
# 사용법: cp .env.example .env.local 후 아래 값들을 채울 것.

# ─── YouTube Data API v3 ───
# 발급: https://console.cloud.google.com/  → "사용자 인증 정보" → API 키
# 주의: search.list 호출 금지 (1회 100 units). 본 프로젝트는 playlistItems.list만 사용.
TUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_DATA_API_ENABLED=true
YOUTUBE_SEARCH_DAILY_LIMIT=20

# ─── 네이버 검색/블로그 API ───
# 발급: https://developers.naver.com/apps/  → 애플리케이션 등록
# 필요한 API: "검색" (블로그·웹문서)
NAVER_CLIENT_ID=your_naver_client_id_here
NAVER_CLIENT_SECRET=your_naver_client_secret_here
